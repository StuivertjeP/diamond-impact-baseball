---
import { coaches } from '../../data/coaches';
---
<section class="section coaches-section" id="coaches" aria-labelledby="coaches-h">
  <div class="container">
    <div class="sh reveal">
      <p class="label-tag">Train met de besten</p>
      <h2 class="impact sh-title" id="coaches-h">COACHES UIT<br/><em>AMERICA &amp; NL</em></h2>
      <p class="sh-body">
        Ons coachingsteam combineert Minor League en Major League ervaring uit de VS met top-Nederlandse spelers die op het hoogste Europese niveau hebben gecompeteerd. Open voor jongens én meisjes.
      </p>
    </div>

    <div class="coach-grid">
      {coaches.map(coach => (
        <div class={`coach-card reveal${coach.delay ? ` ${coach.delay}` : ''}`}>
          <div class="coach-img">
            {coach.photo
              ? <img src={coach.photo} alt={coach.name} style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;" />
              : (
                <>
                  <svg class="coach-sil" viewBox="0 0 80 120" fill="white">
                    <ellipse cx="40" cy="28" rx="17" ry="17"/>
                    <path d="M12 108 Q12 72 40 66 Q68 72 68 108Z"/>
                  </svg>
                  <span class="coach-note">Foto volgt</span>
                </>
              )
            }
            <div class="coach-flag">{coach.flag}</div>
            <div class="coach-level">{coach.level}</div>
          </div>
          <div class="coach-body">
            <h3>{coach.name}</h3>
            <p class="coach-role">{coach.role}</p>
            <p class="coach-bio">{coach.bio}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="partner-bar reveal">
      <div class="partner-card">
        <div class="partner-logo">FCA</div>
        <div class="partner-card-text">
          <h4>FCA Netherlands</h4>
          <p>Fellowship of Christian Athletes — meer dan 70 jaar actief in sport en geloof in 100+ landen. Verantwoordelijk voor de optionele geloofsmomenten, altijd sportergestuurd.</p>
        </div>
      </div>
      <div class="partner-card">
        <div class="partner-logo" style="font-size:.65rem;letter-spacing:.01em;text-align:center;line-height:1.2;">CEL<br/>CHU</div>
        <div class="partner-card-text">
          <h4>Celebration Church Hilversum</h4>
          <p>Mede-organisator van Diamond Impact. Praktische logistiek, gemeenschap en een plek waar iedereen welkom is — gelovig of niet.</p>
        </div>
      </div>
    </div>
  </div>
</section>
